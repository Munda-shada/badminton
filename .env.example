NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Optional: canonical site URL for metadata (Open Graph, canonical). Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional: skip auto-seed count checks (saves 2+ DB round trips per request). Use only after the club tables are populated.
# CLUB_SKIP_SEED_CHECK=1
